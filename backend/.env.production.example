APP_NAME="Alumni Event Management"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.ams.example.com
FRONTEND_URL=https://ams.example.com

APP_TIMEZONE=Asia/Dhaka
LOG_CHANNEL=stack
LOG_LEVEL=warning

# ---------- PostgreSQL ----------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ams_production
DB_USERNAME=ams
DB_PASSWORD=change-me-strong

# ---------- Redis (cache, session, queue) ----------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=change-me
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=.ams.example.com
QUEUE_CONNECTION=redis

# ---------- Sanctum / CORS ----------
SANCTUM_STATEFUL_DOMAINS=ams.example.com

# ---------- Mail (configure via Settings UI or here) ----------
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@ams.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------- Payments ----------
PAYMENT_MODE=live
PAYMENT_CURRENCY=BDT
SSLCZ_STORE_ID=
SSLCZ_STORE_PASSWORD=
SSLCZ_SANDBOX=false
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_SANDBOX=false
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PUBLIC_KEY=
NAGAD_PRIVATE_KEY=
NAGAD_SANDBOX=false

# ---------- SMS ----------
SMS_DRIVER=twilio
SMS_FROM=AMS
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ---------- Analytics ----------
ANALYTICS_CACHE_TTL=300

# ---------- Filesystem (use S3 at scale) ----------
FILESYSTEM_DISK=public
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-south-1
# AWS_BUCKET=ams-uploads
